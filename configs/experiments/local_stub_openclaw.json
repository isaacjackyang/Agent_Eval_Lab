{
  "config_id": "local_stub_openclaw_v1",
  "runner": "openclaw_cli",
  "max_steps": 8,
  "time_budget_sec": 30,
  "weights": {
    "success": 0.35,
    "verifier_pass": 0.2,
    "tool_correctness": 0.15,
    "recovery": 0.1,
    "efficiency": 0.1,
    "honesty_boundary": 0.1
  },
  "efficiency_caps": {
    "tokens": 1200,
    "steps": 8,
    "time_sec": 30,
    "retries": 3
  },
  "fitness_mode": "fitness_weighted_v1",
  "layer_a_proxy_score": 1.0,
  "regression_suite": {
    "path": "benchmarks/layer_b/regression_suite.json",
    "min_pass_rate": 0.75
  },
  "baseline_gate": {
    "min_candidate_fitness": 0.8,
    "min_fitness_gain": 0.0,
    "max_stability_drop": 0.08,
    "min_regression_pass_rate": 0.75,
    "min_honesty_score": 0.95,
    "rollback_on_fitness_drop": 0.03
  },
  "nightly": {
    "candidate_pool_size": 4,
    "candidate_runs_per_config": 4,
    "include_base_config": true,
    "heat_map": {
      "scan": {
        "start_layer_min": 0,
        "end_layer_max": 79,
        "min_block_len": 1,
        "max_block_len": 8,
        "repeat_count": 1
      },
      "probe_a": {
        "label": "Deployment Probe",
        "task_type": "deployment",
        "seeds": [1101, 1103, 1105, 1107]
      },
      "probe_b": {
        "label": "Handoff Probe",
        "task_type": "handoff",
        "seeds": [2101, 2103, 2105, 2107]
      },
      "top_k": 5,
      "verify": {
        "enabled": true,
        "candidate_runs_per_config": 6,
        "top_k": 5
      }
    }
  },
  "openclaw": {
    "command": [
      "python",
      "scripts/fixtures/openclaw_cli_stub.py"
    ],
    "base_config_path": "configs/openclaw/base_openclaw.json",
    "agent_id_prefix": "eval-lab",
    "local": true,
    "timeout_sec": 30,
    "thinking": "low",
    "cleanup_agent": true,
    "cleanup_runtime_dir": false
  },
  "relayer": {
    "enabled": false,
    "mode": "metadata_only",
    "num_layers": 80,
    "start_layer": 2,
    "end_layer": 4,
    "repeat_count": 1,
    "runtime_backend": {
      "command": [
        "python",
        "scripts/fixtures/relayer_runtime_stub.py"
      ]
    },
    "mock_probe": {
      "probe_name": "mock_relayer_probe_v1",
      "preferred_start_layer": 36,
      "preferred_end_layer": 42,
      "preferred_repeat_count": 1
    },
    "scan": {
      "start_layer_min": 0,
      "end_layer_max": 79,
      "min_block_len": 1,
      "max_block_len": 8,
      "repeat_count": 1,
      "runtime_mode": "runtime_patch",
      "verify": {
        "enabled": true,
        "candidate_runs_per_config": 2,
        "top_k": 2,
        "seed_start": 25000
      }
    }
  },
  "sandbox": {
    "backend": "docker",
    "mode": "all",
    "scope": "agent",
    "workspace_access": "read-write",
    "docker_image": "openclaw-sandbox:bookworm-slim",
    "docker_network": "none",
    "container_prefix": "openclaw-eval-lab",
    "memory": "512m",
    "cpus": 1,
    "recreate_on_prepare": true,
    "prune_after_run": true
  },
  "restore": {
    "strategy": "diff",
    "cleanup_after_restore": false
  },
  "paths": {
    "reports_dir": "reports",
    "runs_dir": "runs",
    "db_path": "runs/eval_lab.db",
    "baseline_path": "configs/baselines/local_stub_best_stable_config.json"
  }
}
