{
  "config_id": "local_llama_cpp_agent_v1",
  "runner": "llama_cpp_agent",
  "max_steps": 6,
  "time_budget_sec": 45,
  "weights": {
    "success": 0.35,
    "verifier_pass": 0.2,
    "tool_correctness": 0.15,
    "recovery": 0.1,
    "efficiency": 0.1,
    "honesty_boundary": 0.1
  },
  "efficiency_caps": {
    "tokens": 2000,
    "steps": 6,
    "time_sec": 45,
    "retries": 3
  },
  "fitness_mode": "fitness_weighted_v1",
  "layer_a_proxy_score": 1.0,
  "regression_suite": {
    "path": "benchmarks/layer_b/regression_suite.json",
    "min_pass_rate": 0.75
  },
  "baseline_gate": {
    "min_candidate_fitness": 0.75,
    "min_fitness_gain": 0.0,
    "max_stability_drop": 0.08,
    "min_regression_pass_rate": 0.75,
    "min_honesty_score": 0.95,
    "rollback_on_fitness_drop": 0.03
  },
  "nightly": {
    "candidate_pool_size": 4,
    "candidate_runs_per_config": 4,
    "include_base_config": true,
    "heat_map": {
      "x_axis": "agent_architecture.search_result_limit",
      "x_values": [4, 5, 6, 8],
      "y_axis": "agent_architecture.query_policy",
      "y_values": ["focused_only", "focused_then_broad", "broad_then_focused"],
      "top_k": 5,
      "verify": {
        "enabled": true,
        "candidate_runs_per_config": 6,
        "top_k": 5
      }
    }
  },
  "llama_cpp": {
    "openclaw_state_dir": "C:\\Users\\JackYang\\.openclaw",
    "provider": "llama-cpp",
    "base_url": "http://127.0.0.1:8080/v1",
    "model": "gemma-4-31B-it-Q5_K_M.gguf",
    "timeout_sec": 90,
    "temperature": 0.0,
    "max_output_tokens": 256
  },
  "openclaw": {
    "command": [
      "openclaw"
    ],
    "agent_id_prefix": "eval-lab",
    "local": true,
    "timeout_sec": 90,
    "thinking": "low",
    "cleanup_agent": true,
    "cleanup_runtime_dir": false
  },
  "relayer": {
    "enabled": false,
    "mode": "metadata_only",
    "num_layers": 80,
    "start_layer": 2,
    "end_layer": 4,
    "repeat_count": 1,
    "mock_probe": {
      "probe_name": "mock_relayer_probe_v1",
      "preferred_start_layer": 36,
      "preferred_end_layer": 42,
      "preferred_repeat_count": 1
    },
    "scan": {
      "start_layer_min": 0,
      "end_layer_max": 79,
      "min_block_len": 1,
      "max_block_len": 8,
      "repeat_count": 1
    }
  },
  "sandbox": {
    "backend": "off",
    "mode": "all",
    "scope": "agent",
    "workspace_access": "read-write",
    "recreate_on_prepare": false,
    "prune_after_run": false
  },
  "restore": {
    "strategy": "diff",
    "cleanup_after_restore": false
  },
  "paths": {
    "reports_dir": "reports",
    "runs_dir": "runs",
    "db_path": "runs/eval_lab.db",
    "baseline_path": "configs/baselines/local_stub_best_stable_config.json"
  }
}
